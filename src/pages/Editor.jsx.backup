import React, { useEffect, useState } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { ArrowLeft, Save, Loader2, ChevronLeft, ChevronRight, Download, Share2, Moon, Sun, Plus, Trash2, Copy, Move } from 'lucide-react';
import { useTheme } from '../context/ThemeContext';
import { Panel, PanelGroup, PanelResizeHandle } from 'react-resizable-panels';
import Draggable from 'react-draggable';
import api from '../api/axios';

const TEMPLATE_COLORS = {
  Business: 'from-blue-600 to-blue-800',
  Minimal: 'from-slate-600 to-slate-800',
  Technology: 'from-cyan-600 to-blue-700',
  Education: 'from-green-600 to-teal-700',
  Startup: 'from-orange-500 to-pink-600',
  Creative: 'from-purple-600 to-pink-600',
  Dark: 'from-gray-800 to-gray-950',
  Corporate: 'from-indigo-700 to-indigo-900',
};

const Editor = () => {
  const { id } = useParams();
  const navigate = useNavigate();
  const { theme, toggleTheme } = useTheme();
  const [presentation, setPresentation] = useState(null);
  const [currentSlide, setCurrentSlide] = useState(0);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [editMode, setEditMode] = useState(false);

  useEffect(() => {
    api.get(`/presentations/${id}`)
      .then(res => setPresentation(res.data))
      .catch(() => navigate('/dashboard'))
      .finally(() => setLoading(false));
  }, [id]);

  const handleSave = async () => {
    setSaving(true);
    try {
      await api.put(`/presentations/${id}`, { slides: presentation.slides, title: presentation.title });
    } catch (err) {
      console.error(err);
    } finally {
      setSaving(false);
    }
  };

  const handleExport = async () => {
    try {
      const res = await api.get(`/presentations/${id}/export/pdf`, { responseType: 'blob' });
      const url = window.URL.createObjectURL(new Blob([res.data]));
      const link = document.createElement('a');
      link.href = url;
      link.setAttribute('download', `${presentation.title}.pdf`);
      document.body.appendChild(link);
      link.click();
      link.remove();
    } catch (err) {
      alert('Export failed');
    }
  };

  const handleShare = async () => {
    try {
      const res = await api.post(`/presentations/${id}/share`);
      navigator.clipboard.writeText(res.data.shareLink);
      alert('Share link copied to clipboard!');
    } catch (err) {
      alert('Share failed');
    }
  };

  const updateSlide = (field, value) => {
    const slides = [...presentation.slides];
    slides[currentSlide] = { ...slides[currentSlide], [field]: value };
    setPresentation({ ...presentation, slides });
  };

  const updateBullet = (idx, value) => {
    const content = [...presentation.slides[currentSlide].content];
    content[idx] = value;
    updateSlide('content', content);
  };

  const addBullet = () => {
    const content = [...(presentation.slides[currentSlide].content || []), 'New bullet point'];
    updateSlide('content', content);
  };

  const removeBullet = (idx) => {
    const content = presentation.slides[currentSlide].content.filter((_, i) => i !== idx);
    updateSlide('content', content);
  };

  const addSlide = () => {
    const slides = [...presentation.slides];
    slides.splice(currentSlide + 1, 0, {
      title: 'New Slide',
      content: ['Bullet point 1', 'Bullet point 2'],
      layout: 'title-text',
      notes: ''
    });
    setPresentation({ ...presentation, slides });
    setCurrentSlide(currentSlide + 1);
  };

  const deleteSlide = () => {
    if (presentation.slides.length === 1) return alert('Cannot delete the last slide');
    if (!confirm('Delete this slide?')) return;
    const slides = presentation.slides.filter((_, i) => i !== currentSlide);
    setPresentation({ ...presentation, slides });
    setCurrentSlide(Math.max(0, currentSlide - 1));
  };

  const duplicateSlide = () => {
    const slides = [...presentation.slides];
    slides.splice(currentSlide + 1, 0, { ...presentation.slides[currentSlide] });
    setPresentation({ ...presentation, slides });
    setCurrentSlide(currentSlide + 1);
  };

  if (loading) return (
    <div className="min-h-screen flex items-center justify-center">
      <Loader2 className="w-8 h-8 animate-spin text-indigo-600" />
    </div>
  );

  const slide = presentation.slides[currentSlide];
  const gradient = TEMPLATE_COLORS[presentation.template] || TEMPLATE_COLORS.Minimal;

  return (
    <div className="min-h-screen bg-slate-100 dark:bg-slate-900 flex flex-col">
      {/* Top bar */}
      <div className="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-6 py-3 flex items-center justify-between shadow-sm">
        <button onClick={() => navigate('/dashboard')} className="flex items-center gap-2 text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-200 transition-colors">
          <ArrowLeft className="w-4 h-4" /> Dashboard
        </button>
        <h1 className="font-bold text-slate-900 dark:text-white truncate max-w-xs">{presentation.title}</h1>
        <div className="flex items-center gap-2">
          <button onClick={toggleTheme} className="p-2 text-slate-500 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-colors">
            {theme === 'dark' ? <Sun className="w-5 h-5" /> : <Moon className="w-5 h-5" />}
          </button>
          <button onClick={handleShare} className="p-2 text-slate-500 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-colors" title="Share">
            <Share2 className="w-5 h-5" />
          </button>
          <button onClick={handleExport} className="p-2 text-slate-500 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded-lg transition-colors" title="Export PDF">
            <Download className="w-5 h-5" />
          </button>
          <button onClick={handleSave} disabled={saving} className="flex items-center gap-2 bg-gradient-to-r from-indigo-600 to-purple-600 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:shadow-lg hover:shadow-indigo-200 dark:hover:shadow-indigo-900/50 transition-all disabled:opacity-70">
            {saving ? <Loader2 className="w-4 h-4 animate-spin" /> : <Save className="w-4 h-4" />} Save
          </button>
        </div>
      </div>

      <PanelGroup direction="horizontal" className="flex flex-1 overflow-hidden">
        {/* Slide thumbnails */}
        <Panel defaultSize={15} minSize={10} maxSize={25}>
          <div className="h-full bg-white dark:bg-slate-800 border-r border-slate-200 dark:border-slate-700 overflow-y-auto p-3 space-y-2">
            {presentation.slides.map((s, i) => (
              <button key={i} onClick={() => setCurrentSlide(i)}
                className={`w-full text-left p-2 rounded-xl border transition-all ${i === currentSlide ? 'border-indigo-500 bg-indigo-50 dark:bg-indigo-900/30' : 'border-slate-200 dark:border-slate-600 hover:border-indigo-200 dark:hover:border-indigo-700'}`}>
                <div className={`bg-gradient-to-br ${gradient} rounded-lg h-16 flex items-center justify-center mb-1`}>
                  <span className="text-white text-xs font-bold text-center px-1 line-clamp-2">{s.title}</span>
                </div>
                <p className="text-xs text-slate-500 dark:text-slate-400 text-center">Slide {i + 1}</p>
              </button>
            ))}
          </div>
        </Panel>

        <PanelResizeHandle className="w-1 bg-slate-200 dark:bg-slate-700 hover:bg-indigo-400 dark:hover:bg-indigo-600 transition-colors cursor-col-resize" />

        {/* Main editor */}
        <Panel defaultSize={60} minSize={40}>
          <div className="h-full flex flex-col items-center justify-center p-8 gap-6 bg-slate-50 dark:bg-slate-900">
          {/* Slide preview */}
          <div className={`bg-gradient-to-br ${gradient} rounded-2xl w-full max-w-3xl aspect-video flex flex-col justify-center px-12 py-8 shadow-2xl relative overflow-hidden`}>
            {editMode ? (
              <>
                <Draggable bounds="parent">
                  <div className="absolute cursor-move bg-white/10 backdrop-blur-sm border border-white/30 rounded-lg p-2">
                    <input
                      className="bg-transparent text-white text-3xl font-bold outline-none border-none w-full"
                      value={slide.title}
                      onChange={e => updateSlide('title', e.target.value)}
                    />
                  </div>
                </Draggable>
                <div className="mt-20 space-y-2">
                  {slide.content?.map((point, i) => (
                    <Draggable key={i} bounds="parent">
                      <div className="cursor-move bg-white/10 backdrop-blur-sm border border-white/30 rounded-lg p-2 flex items-start gap-2 w-fit">
                        <span className="mt-1.5 w-1.5 h-1.5 rounded-full bg-white/70 flex-shrink-0" />
                        <input
                          className="bg-transparent text-white/90 text-base outline-none border-none"
                          value={point}
                          onChange={e => updateBullet(i, e.target.value)}
                        />
                      </div>
                    </Draggable>
                  ))}
                </div>
              </>
            ) : (
              <>
                <h2 className="text-white text-3xl font-bold mb-4">{slide.title}</h2>
                <ul className="space-y-2">
                  {slide.content?.map((point, i) => (
                    <li key={i} className="text-white/90 text-base flex items-start gap-2">
                      <span className="mt-1.5 w-1.5 h-1.5 rounded-full bg-white/70 flex-shrink-0" />
                      {point}
                    </li>
                  ))}
                </ul>
              </>
            )}
          </div>

          {/* Navigation */}
          <div className="flex items-center gap-4">
            <button onClick={() => setEditMode(!editMode)} className={`flex items-center gap-1 px-3 py-2 rounded-lg text-xs font-medium transition-all ${editMode ? 'bg-indigo-600 text-white' : 'bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 text-slate-700 dark:text-slate-300'}`}>
              <Move className="w-4 h-4" /> {editMode ? 'Preview' : 'Edit Layout'}
            </button>
            <button onClick={() => setCurrentSlide(i => Math.max(0, i - 1))} disabled={currentSlide === 0}
              className="p-2 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 hover:border-indigo-300 dark:hover:border-indigo-600 disabled:opacity-40 transition-all shadow-sm">
              <ChevronLeft className="w-5 h-5 text-slate-700 dark:text-slate-300" />
            </button>
            <span className="text-sm text-slate-600 dark:text-slate-400 font-medium">{currentSlide + 1} / {presentation.slides.length}</span>
            <button onClick={() => setCurrentSlide(i => Math.min(presentation.slides.length - 1, i + 1))} disabled={currentSlide === presentation.slides.length - 1}
              className="p-2 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 hover:border-indigo-300 dark:hover:border-indigo-600 disabled:opacity-40 transition-all shadow-sm">
              <ChevronRight className="w-5 h-5 text-slate-700 dark:text-slate-300" />
            </button>
          </div>

          {/* Slide actions */}
          <div className="flex items-center gap-2">
            <button onClick={addSlide} className="flex items-center gap-1 px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 rounded-lg text-xs font-medium text-slate-700 dark:text-slate-300 hover:border-indigo-300 dark:hover:border-indigo-600 transition-all" title="Add slide">
              <Plus className="w-4 h-4" /> Add
            </button>
            <button onClick={duplicateSlide} className="p-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 rounded-lg text-slate-700 dark:text-slate-300 hover:border-indigo-300 dark:hover:border-indigo-600 transition-all" title="Duplicate slide">
              <Copy className="w-4 h-4" />
            </button>
            <button onClick={deleteSlide} className="p-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 rounded-lg text-slate-700 dark:text-slate-300 hover:border-red-300 dark:hover:border-red-600 hover:text-red-500 transition-all" title="Delete slide">
              <Trash2 className="w-4 h-4" />
            </button>
          </div>
          </div>
        </Panel>

        <PanelResizeHandle className="w-1 bg-slate-200 dark:bg-slate-700 hover:bg-indigo-400 dark:hover:bg-indigo-600 transition-colors cursor-col-resize" />

        {/* Edit panel */}
        <Panel defaultSize={25} minSize={20} maxSize={35}>
          <div className="h-full bg-white dark:bg-slate-800 border-l border-slate-200 dark:border-slate-700 p-5 overflow-y-auto">
          <h3 className="font-bold text-slate-900 dark:text-white mb-4">Edit Slide {currentSlide + 1}</h3>

          <div className="space-y-4">
            <div>
              <label className="block text-xs font-semibold text-slate-600 dark:text-slate-400 mb-1">Title</label>
              <input
                className="w-full px-3 py-2 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-600 rounded-xl text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 outline-none"
                value={slide.title}
                onChange={e => updateSlide('title', e.target.value)}
              />
            </div>

            <div>
              <div className="flex items-center justify-between mb-1">
                <label className="block text-xs font-semibold text-slate-600 dark:text-slate-400">Bullet Points</label>
                <button onClick={addBullet} className="text-xs text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium flex items-center gap-1">
                  <Plus className="w-3 h-3" /> Add
                </button>
              </div>
              <div className="space-y-2">
                {slide.content?.map((point, i) => (
                  <div key={i} className="flex gap-2">
                    <textarea rows={2}
                      className="flex-1 px-3 py-2 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-600 rounded-xl text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 outline-none resize-none"
                      value={point}
                      onChange={e => updateBullet(i, e.target.value)}
                    />
                    <button onClick={() => removeBullet(i)} className="p-2 text-slate-400 hover:text-red-500 transition-colors">
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </div>
                ))}
              </div>
            </div>

            {slide.notes !== undefined && (
              <div>
                <label className="block text-xs font-semibold text-slate-600 dark:text-slate-400 mb-1">Speaker Notes</label>
                <textarea rows={3}
                  className="w-full px-3 py-2 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-600 rounded-xl text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 outline-none resize-none"
                  value={slide.notes}
                  onChange={e => updateSlide('notes', e.target.value)}
                />
              </div>
            )}
          </div>
        </Panel>
      </PanelGroup>
    </div>
  );
};

export default Editor;
